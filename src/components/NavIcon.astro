---
import type { NavIconName } from "../data/nav";

interface Props {
	name: NavIconName;
}

const { name } = Astro.props;
---

<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
	{
		name === "overview" && (
			<>
				<rect x="4" y="4" width="7" height="7" rx="1.5" />
				<rect x="13" y="4" width="7" height="7" rx="1.5" />
				<rect x="4" y="13" width="7" height="7" rx="1.5" />
				<rect x="13" y="13" width="7" height="7" rx="1.5" />
			</>
		)
	}
	{
		name === "brand" && (
			<>
				<circle cx="12" cy="10" r="5" />
				<path d="M8 20c1.5-2.5 6.5-2.5 8 0" />
				<path d="M10 9h.01M14 9h.01M10.5 12c.8.8 2.2.8 3 0" />
			</>
		)
	}
	{
		name === "voice" && (
			<>
				<path d="M5 10v4" />
				<path d="M9 7v10" />
				<path d="M13 4v16" />
				<path d="M17 8v8" />
				<path d="M21 11v2" />
			</>
		)
	}
	{
		name === "visuals" && (
			<>
				<rect x="3.5" y="5" width="17" height="14" rx="2" />
				<circle cx="9" cy="11" r="1.6" />
				<path d="M3.5 16l4.5-4 3.5 3 3-2.5 6 5.5" />
			</>
		)
	}
	{
		name === "assets" && (
			<>
				<path d="M4 8.5 12 4l8 4.5v7L12 20l-8-4.5v-7Z" />
				<path d="M12 12v8M4 8.5l8 3.5 8-3.5" />
			</>
		)
	}
	{
		name === "templates" && (
			<>
				<path d="M7 4h7l4 4v12a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1Z" />
				<path d="M14 4v4h4" />
				<path d="M9 13h6M9 16h4" />
			</>
		)
	}
	{
		name === "guidelines" && (
			<>
				<path d="M8 5h10v14H8a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" />
				<path d="M10 9h6M10 12h6M10 15h4" />
			</>
		)
	}
	{
		name === "resources" && (
			<>
				<path d="M5 7a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V7Z" />
				<path d="M9 11h6M9 14h4" />
			</>
		)
	}
	{
		name === "changelog" && (
			<>
				<path d="M8 4v3M16 4v3" />
				<rect x="5" y="6" width="14" height="14" rx="2" />
				<path d="M9 13h6M9 16h3" />
			</>
		)
	}
	{
		name === "contact" && (
			<>
				<path d="M4 7.5A2.5 2.5 0 0 1 6.5 5h11A2.5 2.5 0 0 1 20 7.5v9a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 4 16.5v-9Z" />
				<path d="m5 8 7 5 7-5" />
			</>
		)
	}
</svg>

<style>
	.nav-icon {
		width: 1.05rem;
		height: 1.05rem;
		flex-shrink: 0;
	}
</style>

		{
			heading: "Launch Note",
			body: "What shipped, why it matters, how to try it, and known edges — written in studio voice.",
		},
		{
			heading: "Project Checklist",
			body: "Brand review, naming, assets, accessibility pass, and changelog entry before anything public.",
		},
	]}
/>
